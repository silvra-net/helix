{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helix Wallet",
  "identifier": "net.silvra.helix.wallet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node scripts/sync-version.mjs && npm run dev",
    "beforeBuildCommand": "node scripts/sync-version.mjs && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Helix Wallet",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://helix.silvra.net http://127.0.0.1:8545 http://localhost:8545"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/helix"]
  }
}
